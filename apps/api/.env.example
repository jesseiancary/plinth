# Database
# Must match credentials in root .env file (used by docker-compose.yml)
# Format: postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:POSTGRES_PORT/POSTGRES_DB
DATABASE_URL=postgresql://plinth_dev:your-generated-password-here@localhost:5432/plinth_dev

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Environment
NODE_ENV=development
PORT=3000
