# Docker Compose Environment Variables
# Copy this file to .env and update with your local values.
# Generate a strong password using: openssl rand -base64 32

# PostgreSQL Database Credentials
# These values are used by docker-compose.yml for container configuration.
# The same credentials should be referenced in apps/api/.env DATABASE_URL.
POSTGRES_USER=plinth_dev
POSTGRES_PASSWORD=your-generated-password-here
POSTGRES_DB=plinth_dev
POSTGRES_PORT=5432
